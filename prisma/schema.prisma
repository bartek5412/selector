generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}
// Definicja tabeli dla konfiguracji SmartFrame
model SmartFrame {
  id          String    @id @default(cuid())
  kolorRamy   String
  kolorSzkla  String
  szerokosc   Float
  wysokosc    Float
//  createdAt   DateTime  @default(now())
}
model LetterOption {
    id          String    @id @default(cuid())
    name String
    description String
    price Float
    elementType String
    elementValue Float?
    margin Float?
    unit String?
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}

model Letter {
    id          String    @id @default(cuid())
    name        String
    description String
    type        String
    createdAt   DateTime  @default(now())
    updatedAt   DateTime  @updatedAt
}